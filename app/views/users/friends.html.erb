<section class="space-y-6">
  <div>
    <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Friends</p>
    <h1 class="mt-2 text-4xl leading-tight text-[#141413]"><%= display_name(@user) %>'s connections.</h1>
    <p class="mt-3 max-w-2xl text-[15px] leading-7 text-[#5e5d59]">Accepted follow requests become part of this list.</p>
  </div>

  <% if @friends.any? %>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      <% @friends.each do |friend| %>
        <article class="<%= [card_classes, 'p-6'].join(' ') %>">
          <h2 class="text-2xl leading-tight text-[#141413]"><%= display_name(friend) %></h2>
          <p class="mt-1 text-sm text-[#87867f]"><%= user_handle(friend) %></p>
          <p class="mt-4 text-sm leading-6 text-[#5e5d59]"><%= friend.profile&.bio.presence || "No bio yet." %></p>
          <div class="mt-6 flex flex-wrap gap-3">
            <%= link_to "View profile", user_path(friend), class: primary_button_classes %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No friends yet", body: "Accepted requests will appear here once connections form." %>
  <% end %>
</section>
