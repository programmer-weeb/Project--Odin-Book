<section class="space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Network</p>
      <h1 class="mt-2 text-4xl leading-tight text-[#141413]">Browse people in Odin Book.</h1>
      <p class="mt-3 max-w-2xl text-[15px] leading-7 text-[#5e5d59]">Profiles pull from user, profile, and follow-request records. Send request when you want to open a friend connection.</p>
    </div>
    <%= link_to "View my profile", user_path(current_user), class: primary_button_classes %>
  </div>

  <% if @users.any? %>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      <% @users.each do |user| %>
        <%= render "user_card", user: user, friend_ids: @friend_ids, sent_request_user_ids: @sent_request_user_ids, received_request_user_ids: @received_request_user_ids %>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No people yet", body: "User directory will appear here once accounts exist." %>
  <% end %>
</section>
