<article class="<%= [card_classes, 'flex h-full flex-col justify-between p-6'].join(' ') %>">
  <div>
    <div class="flex items-start justify-between gap-3">
      <div>
        <h3 class="text-2xl leading-tight text-[#141413]"><%= display_name(user) %></h3>
        <p class="mt-1 text-sm text-[#87867f]"><%= user_handle(user) %></p>
      </div>

      <% if user == current_user %>
        <span class="rounded-full bg-[#ece9df] px-3 py-1 text-xs font-medium text-[#5e5d59]">You</span>
      <% elsif friend_ids.include?(user.id) %>
        <span class="rounded-full px-3 py-1 text-xs font-medium <%= status_badge_classes('friend') %>">Friend</span>
      <% elsif sent_request_user_ids.include?(user.id) || received_request_user_ids.include?(user.id) %>
        <span class="rounded-full px-3 py-1 text-xs font-medium <%= status_badge_classes('pending') %>">Pending</span>
      <% end %>
    </div>

    <p class="mt-4 text-sm leading-6 text-[#5e5d59]"><%= user.profile&.bio.presence || "No bio yet." %></p>
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    <%= link_to "View profile", user_path(user), class: primary_button_classes %>
    <%= link_to "Friends", friends_user_path(user), class: secondary_button_classes %>

    <% unless user == current_user %>
      <% fr_status = if friend_ids.include?(user.id) then "accepted"
                     elsif sent_request_user_ids.include?(user.id) || received_request_user_ids.include?(user.id) then "pending"
                     else "none"
                     end %>
      <%= render "users/friend_request_actions",
            user: user,
            friendship_status: fr_status,
            pending_sent_request: nil,
            pending_received_request: nil %>
    <% end %>
  </div>
</article>
