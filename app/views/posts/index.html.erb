<div class="grid gap-8 lg:grid-cols-[minmax(0,24rem)_minmax(0,1fr)]">
  <section class="space-y-6">
    <div>
      <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Feed</p>
      <h1 class="mt-2 text-4xl leading-tight text-[#141413]">Share something worth reading.</h1>
      <p class="mt-3 max-w-md text-[15px] leading-7 text-[#5e5d59]">Post to the network, browse recent conversations, and keep the tone deliberate.</p>
    </div>

    <div class="<%= [card_classes, 'p-6'].join(' ') %>">
      <h2 class="text-2xl text-[#141413]">New post</h2>
      <p class="mt-2 text-sm leading-6 text-[#5e5d59]">Your post appears in the shared feed immediately after publish.</p>
      <div class="mt-5">
        <%= render "form", post: @post, submit_label: "Publish post", rows: 8 %>
      </div>
    </div>
  </section>

  <section class="space-y-5">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <%= render "post_card", post: post, likes_by_post_id: @likes_by_post_id %>
      <% end %>
    <% else %>
      <%= render "shared/empty_state", title: "No posts yet", body: "Start conversation with first post. Feed will fill as people publish updates and respond." %>
    <% end %>
  </section>
</div>
