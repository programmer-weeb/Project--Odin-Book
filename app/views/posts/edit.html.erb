<section class="mx-auto max-w-3xl">
  <div class="<%= [card_classes, 'p-6 sm:p-8'].join(' ') %>">
    <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Edit</p>
    <h1 class="mt-2 text-4xl leading-tight text-[#141413]">Refine your post.</h1>
    <p class="mt-3 text-[15px] leading-7 text-[#5e5d59]">Update wording, add detail, or tighten argument before people return to it.</p>
    <div class="mt-6">
      <%= render "form", post: @post, submit_label: "Save changes", rows: 10 %>
    </div>
  </div>
</section>
