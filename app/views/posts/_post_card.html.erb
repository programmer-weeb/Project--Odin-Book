<% like = likes_by_post_id[post.id] if local_assigns[:likes_by_post_id] %>
<article class="<%= [card_classes, 'p-6'].join(' ') %>">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="font-serif text-2xl text-[#141413]"><%= display_name(post.user) %></p>
      <div class="mt-1 flex flex-wrap items-center gap-2 text-sm text-[#87867f]">
        <span><%= user_handle(post.user) %></span>
        <span>&bull;</span>
        <span><%= friendly_timestamp(post.created_at) %></span>
      </div>
    </div>

    <% if post.user == current_user %>
      <div class="flex items-center gap-2">
        <%= link_to "Edit", edit_post_path(post), class: secondary_button_classes %>
        <%= button_to "Delete", post_path(post), method: :delete, class: secondary_button_classes, form: { data: { turbo_confirm: "Delete this post?" } } %>
      </div>
    <% end %>
  </div>

  <div class="mt-5 whitespace-pre-wrap text-[15px] leading-7 text-[#3d3d3a]">
    <%= post.content %>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-3 border-t border-[#e8e6dc] pt-4">
    <% if like %>
      <%= button_to "Unlike (#{post.likes_count})", like_path(like), method: :delete, class: secondary_button_classes %>
    <% else %>
      <%= button_to "Like (#{post.likes_count})", post_likes_path(post), method: :post, class: primary_button_classes %>
    <% end %>

    <%= link_to "#{pluralize(post.comments_count, 'comment')}", post_path(post), class: secondary_button_classes %>
    <%= link_to "View post", post_path(post), class: subtle_button_classes %>
    <%= link_to display_name(post.user), user_path(post.user), class: subtle_button_classes %>
  </div>
</article>
