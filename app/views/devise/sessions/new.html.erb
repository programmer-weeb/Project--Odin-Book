<section class="mx-auto max-w-xl">
  <div class="<%= [card_classes, 'p-6 sm:p-8'].join(' ') %>">
    <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Welcome back</p>
    <h1 class="mt-2 text-4xl leading-tight text-[#141413]">Sign in to Odin Book.</h1>
    <p class="mt-3 text-[15px] leading-7 text-[#5e5d59]">Pick up your feed, profile, requests, and ongoing conversations.</p>

    <% if google_oauth_enabled? %>
      <div class="mt-6">
        <%= button_to "Continue with Google", user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false }, class: secondary_button_classes %>
      </div>
    <% end %>

    <%= form_for resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-5" } do |form| %>
      <div>
        <%= form.label :email, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", class: input_classes %>
      </div>

      <div>
        <%= form.label :password, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.password_field :password, autocomplete: "current-password", class: input_classes %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-3 text-sm text-[#5e5d59]">
          <%= form.check_box :remember_me, class: "h-4 w-4 rounded border-[#d9d4c7] text-[#c96442] focus:ring-[#3898ec]" %>
          <span>Remember me</span>
        </label>
      <% end %>

      <div class="flex flex-wrap gap-3">
        <%= form.submit "Sign in", class: primary_button_classes %>
        <%= link_to "Create account", new_registration_path(resource_name), class: secondary_button_classes %>
        <%= link_to "Forgot password?", new_password_path(resource_name), class: subtle_button_classes %>
      </div>
    <% end %>
  </div>
</section>
