<section class="mx-auto max-w-xl">
  <div class="<%= [card_classes, 'p-6 sm:p-8'].join(' ') %>">
    <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Account</p>
    <h1 class="mt-2 text-4xl leading-tight text-[#141413]">Update account settings.</h1>

    <%= form_for resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "mt-6 space-y-5" } do |form| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= form.label :email, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", class: input_classes %>
      </div>

      <div>
        <%= form.label :password, "New password", class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.password_field :password, autocomplete: "new-password", class: input_classes %>
      </div>

      <div>
        <%= form.label :password_confirmation, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", class: input_classes %>
      </div>

      <div>
        <%= form.label :current_password, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.password_field :current_password, autocomplete: "current-password", class: input_classes %>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= form.submit "Save account", class: primary_button_classes %>
        <%= link_to "Back", request.referer || root_path, class: secondary_button_classes %>
      </div>
    <% end %>
  </div>
</section>
