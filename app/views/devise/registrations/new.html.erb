<section class="mx-auto max-w-xl">
  <div class="<%= [card_classes, 'p-6 sm:p-8'].join(' ') %>">
    <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Join</p>
    <h1 class="mt-2 text-4xl leading-tight text-[#141413]">Create your account.</h1>
    <p class="mt-3 text-[15px] leading-7 text-[#5e5d59]">New users get a default profile automatically, then can edit display name and bio.</p>

    <% if google_oauth_enabled? %>
      <div class="mt-6">
        <%= button_to "Sign up with Google", user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false }, class: secondary_button_classes %>
      </div>
    <% end %>

    <%= form_for resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-6 space-y-5" } do |form| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= form.label :email, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", class: input_classes %>
      </div>

      <div>
        <%= form.label :password, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.password_field :password, autocomplete: "new-password", class: input_classes %>
      </div>

      <div>
        <%= form.label :password_confirmation, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", class: input_classes %>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= form.submit "Create account", class: primary_button_classes %>
        <%= link_to "Sign in", new_session_path(resource_name), class: secondary_button_classes %>
      </div>
    <% end %>
  </div>
</section>
