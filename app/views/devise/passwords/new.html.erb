<section class="mx-auto max-w-xl">
  <div class="<%= [card_classes, 'p-6 sm:p-8'].join(' ') %>">
    <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Reset</p>
    <h1 class="mt-2 text-4xl leading-tight text-[#141413]">Request password reset.</h1>
    <p class="mt-3 text-[15px] leading-7 text-[#5e5d59]">Enter email address tied to account, then Devise will send reset instructions.</p>

    <%= form_for resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-6 space-y-5" } do |form| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= form.label :email, class: "text-sm font-medium text-[#3d3d3a]" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", class: input_classes %>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= form.submit "Send reset link", class: primary_button_classes %>
        <%= link_to "Back to sign in", new_session_path(resource_name), class: secondary_button_classes %>
      </div>
    <% end %>
  </div>
</section>
