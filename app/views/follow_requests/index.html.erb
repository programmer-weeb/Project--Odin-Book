<section class="space-y-8">
  <div>
    <p class="text-sm uppercase tracking-[0.08em] text-[#87867f]">Requests</p>
    <h1 class="mt-2 text-4xl leading-tight text-[#141413]">Manage your follow requests.</h1>
    <p class="mt-3 max-w-2xl text-[15px] leading-7 text-[#5e5d59]">Incoming and outgoing requests live here, with actions based on current status.</p>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <section class="<%= [card_classes, 'p-6'].join(' ') %>">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-3xl leading-tight text-[#141413]">Received</h2>
        <%= link_to "Open list", received_follow_requests_path, class: subtle_button_classes %>
      </div>

      <div class="mt-5 space-y-4">
        <% if @received_follow_requests.any? %>
          <% @received_follow_requests.each do |follow_request| %>
            <%= render "follow_request", follow_request: follow_request, other_user: follow_request.requesting_user, received_actions: true %>
          <% end %>
        <% else %>
          <%= render "shared/empty_state", title: "Nothing received", body: "Incoming requests will show up here when someone asks to connect." %>
        <% end %>
      </div>
    </section>

    <section class="<%= [card_classes, 'p-6'].join(' ') %>">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-3xl leading-tight text-[#141413]">Sent</h2>
        <%= link_to "Open list", sent_follow_requests_path, class: subtle_button_classes %>
      </div>

      <div class="mt-5 space-y-4">
        <% if @sent_follow_requests.any? %>
          <% @sent_follow_requests.each do |follow_request| %>
            <%= render "follow_request", follow_request: follow_request, other_user: follow_request.requested_user %>
          <% end %>
        <% else %>
          <%= render "shared/empty_state", title: "Nothing sent", body: "Send a request from someone else's profile to start a connection." %>
        <% end %>
      </div>
    </section>
  </div>
</section>
